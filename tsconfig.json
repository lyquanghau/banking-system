{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "hardhat"]
  },
  "include": ["./deploy/**/*.ts", "./scripts/**/*.ts", "./test/**/*.ts", "./hardhat.config.ts"]
}
